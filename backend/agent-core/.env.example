NODE_ENV=production
HOST=0.0.0.0
PORT=3000

OPENAI_API_KEY=your-openai-compatible-key
OPENAI_MODEL_NAME=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# Raw LLM HTTP log (dev / troubleshooting only). When true, 1, yes, or on: wraps the OpenAI client fetch and
# writes logs/llmOrg.log as one pretty-printed JSON array (section markers after each response; ~10 round-trips kept). Bodies truncated by default ~512KB each. Authorization-style
# headers are redacted; JSON body may still contain API keys. Default: off (omit or set false).
# LLM_RAW_HTTP_LOG=true
# Optional: max UTF-16 code units logged per request/response body (default 524288).
# LLM_RAW_HTTP_LOG_MAX_BODY_CHARS=1048576
#
# When true: also POST each llmOrg-equivalent record to skill-gateway (JAVA_GATEWAY_URL + JAVA_GATEWAY_TOKEN) for DB persistence.
# Agent-core does not connect to the database; gateway writes llm_http_audit_logs. Can be used with or without local LLM_RAW_HTTP_LOG.
# LLM_ORG_LOG_REMOTE=true

# Inbound POST /agent/run payload log (dev only). When true, 1, yes, or on: append one NDJSON line per run to logs/agentRun.log
# (or AGENT_RUN_RAW_LOG_PATH relative to cwd / absolute). Context/history are deep-redacted for apiKey/token/password-like keys.
# User text remains — may contain PII. Default: off.
# AGENT_RUN_RAW_LOG=true
# Optional: max serialized line length (default 524288). If exceeded, a short placeholder line is written instead.
# AGENT_RUN_RAW_LOG_MAX_CHARS=1048576
# Optional: override log file path (default logs/agentRun.log under cwd).
# AGENT_RUN_RAW_LOG_PATH=logs/agentRun.log

JAVA_GATEWAY_URL=http://127.0.0.1:18080
JAVA_GATEWAY_TOKEN=your-secure-token-here

# Built-in tools (api_caller / compute / ssh_executor): legacy = direct /api/skills/api, /compute, /ssh; gateway = POST /api/system-skills/execute (system_skills in DB). Extension EXTENSION skills ignore this. Code default if unset: legacy.
AGENT_BUILTIN_SKILL_DISPATCH=legacy

# When set to 1 or true: expose the built-in ssh_executor tool to the LLM for authenticated sessions.
# Default: omit or false — authenticated users only use extension SSH skills + gateway SSH (command from saved skill).
# AGENT_EXPOSE_SSH_EXECUTOR=true

MEM0_URL=http://127.0.0.1:8001
# Set to false to skip mem0 retrieval (msearch) and turn storage (madd)
MEM0_ENABLED=true
LLM_RAW_HTTP_LOG=true
# Optional: larger cap for llmOrg.log bodies (default 524288 UTF-16 units)
LLM_RAW_HTTP_LOG_MAX_BODY_CHARS=1048576

# POST /agent/run 入参落盘 logs/agentRun.log（脱敏 apiKey/token 等键；对话原文仍会记录）
AGENT_RUN_RAW_LOG=true
AGENT_RUN_RAW_LOG_MAX_CHARS=1048576
AGENT_RUN_RAW_LOG_PATH=logs/agentRun.log

# AGENT_TOOL_PROMPT_COMPAT=true

# 将 llmOrg 等价记录 POST 到 skill-gateway 写入 MySQL（llm_http_audit_logs）；需 JAVA_GATEWAY_URL + JAVA_GATEWAY_TOKEN；agent-core 不直连数据库
LLM_ORG_LOG_REMOTE=true